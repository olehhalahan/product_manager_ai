# Session secret for cookies (required for auth)
SESSION_SECRET=your-random-secret-at-least-32-chars

# Google Tag Manager container. GA4 via GTM: Google Tag / GA4 Config, Trigger: All Pages
GTM_CONTAINER_ID=GTM-W25B668S

# Google Search Console HTML tag verification (optional; default is set in app if unset)
# GOOGLE_SITE_VERIFICATION=PBIv7Juyd9qX3pFJ-8NbZXkVKhMy0jdQZd3YvG1WiB8

# Database: SQLite by default
# Server: DATABASE_URL=sqlite:////var/www/product_manager_ai/app.db
# Local: omit for data/app.db, or use sqlite:///./data/app.db
# PostgreSQL: postgresql://postgres:postgres@localhost:5432/product_manager

# Google Cloud — one project for OAuth + APIs (see Console project picker / IAM)
GOOGLE_CLOUD_PROJECT_ID=my-gcp-project-id
# Merchant API: register this GCP project with each Merchant Center account (developer registration):
# https://developers.google.com/merchant/api/guides/quickstart/direct-api-calls#step_1_register_as_a_developer

# Google OAuth (required for login + Merchant Center connection)
# Create OAuth 2.0 Client ID (Web application) in the SAME project as GOOGLE_CLOUD_PROJECT_ID:
# https://console.cloud.google.com/apis/credentials
# Enable "Merchant API" on that project (not the deprecated Content API for Shopping).
# Add authorized redirect URIs:
#   https://yourdomain.com/auth/google/callback
#   https://yourdomain.com/auth/google/merchant/callback
# Add authorized JavaScript origin: https://yourdomain.com
# OAuth consent screen: add scope https://www.googleapis.com/auth/content (Merchant API / Merchant Center)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Merchant Center product push (Merchant API) — language/country for offers (ISO 639-1 / ISO 3166-1 alpha-2)
# GMC_CONTENT_LANGUAGE=en
# GMC_TARGET_COUNTRY=US
# Optional: feed label (default = GMC_TARGET_COUNTRY); must match ProductInput (A–Z, 0–9, -, _; max 20)
# GMC_FEED_LABEL=US
# Merchant Center account id. If you omit this variable entirely, the app uses built-in default 5750677992.
# Do not set GMC_MERCHANT_ID to 5635309342 (wrong account); the app remaps it to 5750677992.
# Override for another deployment: GMC_MERCHANT_ID=5750677992
# To force API discovery (multiple accounts), set GMC_MERCHANT_ID= (empty value) in .env.
# Per-user override without .env: POST /api/merchant/select-account with JSON {"merchant_id":"5750677992"} after OAuth.
# Optional: full primary API data source resource name (skip auto list/create):
# GMC_DATA_SOURCE_NAME=accounts/123456789/dataSources/987654321
# Optional: display name when auto-creating an API primary data source
# GMC_DATA_SOURCE_DISPLAY_NAME=My API feed

# Production: set this when behind reverse proxy (e.g. https://cartozo.ai)
# Ensures OAuth redirect_uri matches Google Console; also disables dev auth
DEPLOY_URL=https://cartozo.ai

# Apple Sign-In (optional)
# Requires Apple Developer account, Service ID, and private key
# https://developer.apple.com/sign-in-with-apple/
APPLE_CLIENT_ID=com.yourapp.service
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX
APPLE_PRIVATE_KEY=/path/to/AuthKey_XXXXXXXXXX.p8
