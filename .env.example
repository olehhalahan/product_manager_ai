# Session secret for cookies (required for auth)
SESSION_SECRET=your-random-secret-at-least-32-chars

# Google Tag Manager container. GA4 via GTM: Google Tag / GA4 Config, Trigger: All Pages
GTM_CONTAINER_ID=GTM-W25B668S

# Database: SQLite by default
# Server: DATABASE_URL=sqlite:////var/www/product_manager_ai/app.db
# Local: omit for data/app.db, or use sqlite:///./data/app.db
# PostgreSQL: postgresql://postgres:postgres@localhost:5432/product_manager

# Google OAuth (required for login)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add authorized redirect URI: https://yourdomain.com/auth/google/callback
# Add authorized JavaScript origin: https://yourdomain.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Production: set this when behind reverse proxy (e.g. https://cartozo.ai)
# Ensures OAuth redirect_uri matches Google Console; also disables dev auth
DEPLOY_URL=https://cartozo.ai

# Apple Sign-In (optional)
# Requires Apple Developer account, Service ID, and private key
# https://developer.apple.com/sign-in-with-apple/
APPLE_CLIENT_ID=com.yourapp.service
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX
APPLE_PRIVATE_KEY=/path/to/AuthKey_XXXXXXXXXX.p8
