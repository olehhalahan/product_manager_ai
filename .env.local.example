# Local development overrides
# Copy to .env.local (gitignored) and adjust
# Values here override .env

# Omit DEPLOY_URL to enable dev auth (/?dev=admin)
# DEPLOY_URL=

# Local database (optional)
# DATABASE_URL=sqlite:///./data/app.db

# OAuth: use localhost URLs in Google Console
# Authorized redirect URI: http://localhost:8000/auth/google/callback
# Authorized JavaScript origin: http://localhost:8000
# DEPLOY_URL=http://localhost:8000
